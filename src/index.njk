<div style="
  font-family: Georgia, serif;
  background:#f6f2ec;
  padding:20px;
">
<!-- Side Images -->
<style>
  .side-image {
    position: fixed;
    top: 20px;
    width: 520px;
    height: 90vh;
    object-fit: cover;
    border-radius: 18px;
    box-shadow: 0 8px 20px rgba(0,0,0,0.12);
    z-index: 1;
    opacity: 0.92;
    filter: brightness(0.95);
  }

  .left-side {
    left: 0px;
    width: 420px;
  }

  .right-side {
    right: 0px;
  }

  @media (max-width: 1400px) {
    .side-image {
      display: none;
    }
  }
</style>

<img src="/images/left_picture1.jpeg" class="side-image left-side" alt="Inspirational image">
<img src="/images/right_picture.jpeg" class="side-image right-side" alt="Divine image">

<div style="max-width:800px; margin:auto;">

<!-- Navbar -->
<div style="
  display:flex;
  justify-content:space-between;
  align-items:center;
  background:white;
  padding:20px 30px;
  border-radius:14px;
  box-shadow:0 6px 18px rgba(0,0,0,0.08);
  margin-bottom:30px;
">
  <!-- Nav links -->
  <div style="display:flex; gap:20px;">
    <a href="/" style="
  text-decoration:none;
  color:#333;
  font-weight:bold;
  font-size:18px;
  transition:0.3s;
" onmouseover="this.style.color='#666'"
  onmouseout="this.style.color='#333'">
  Home
</a>
    <a href="/timeline" style="text-decoration:none; color:#333; font-weight:bold; font-size:18px;
    transition:0.3s;" onmouseover="this.style.color='#666'"
    onmouseout="this.style.color='#333'">Timeline</a>
    <a href="#about" style="text-decoration:none; color:#333; font-weight:bold; font-size:18px;
    transition:0.3s;" onmouseover="this.style.color='#666'"
    onmouseout="this.style.color='#333'">About</a>
  </div>

  <!-- Logo on right -->
  <img src="/images/logo.jpg" alt="Logo" style="width:90px; height:60px; object-fit:contain;">
</div>

  <!-- Header -->
  <div style="text-align:center; margin-bottom:20px;">

  <h1 style="
    font-size: 56px;
    letter-spacing: 2px;
    font-weight: bold;
    margin-bottom: 10px;
  ">
  Lumen Christi
</h1>
  <p style="color:#777;">
    I am powerful when I am with the Lord, than in myself.
  </p>
    <a href="/timeline" style="
      display:inline-block;
      margin-top:10px;
      padding:8px 16px;
      background:#333;
      color:white;
      border-radius:6px;
      text-decoration:none;
    ">
      View Timeline
    </a>
  </div>

  

  <hr>

  <!-- ✅ FIX: Use Eleventy collection -->
  {% set postsOnly = collections.posts %}
  {% set latestPost = postsOnly | sort(attribute="date") | reverse | first %}

  <!-- 🌅 Today's Message -->
  <div style="
    background:white;
    padding:30px;
    border-radius:12px;
    box-shadow:0 6px 20px rgba(0,0,0,0.08);
    text-align:center;
    margin-bottom:30px;
  ">
    <h2> Today’s Message</h2>

    <h3>
      <a href="{{ latestPost.url }}" style="text-decoration:none; color:#333;">
        {{ latestPost.data.title }}
      </a>
    </h3>

    <p style="color:#888;">
      {{ latestPost.date | formatDate }}
    </p>

    <a href="{{ latestPost.url }}" style="
      display:inline-block;
      margin-top:15px;
      padding:10px 20px;
      background:#333;
      color:white;
      border-radius:6px;
      text-decoration:none;
    ">
      Read More →
    </a>
  </div>

  <!-- 🎲 Random Button -->
  <div style="text-align:center; margin:20px;">
    <button onclick="randomPost()" style="
      padding:10px 20px;
      border:none;
      background:#444;
      color:white;
      border-radius:6px;
      cursor:pointer;
    ">
      Random Message
    </button>
  </div>

  <!-- 📚 Posts List -->
  <ul id="postList" style="list-style:none; padding:0;">
  {% for post in postsOnly | sort(attribute="date") | reverse %}
    <li class="post-item" style="
      display:none;
      background:white;
      padding:20px;
      margin-bottom:15px;
      border-radius:10px;
      box-shadow:0 6px 15px rgba(0,0,0,0.08);
      transition: transform 0.2s;
    ">
      <a href="{{ post.url }}" style="
        text-decoration:none;
        font-size:18px;
        color:#333;
      ">
        {{ post.data.title }}
      </a>
      <br>
      <small style="color:#888;">
        {{ post.date | formatDate }}
      </small>
    </li>
  {% endfor %}
  </ul>

  <!-- Load More -->
  <div style="text-align:center; margin-top:20px;">
    <button onclick="loadMore()" style="
      padding:10px 20px;
      background:#333;
      color:white;
      border:none;
      border-radius:6px;
      cursor:pointer;
    ">
      Load More
    </button>
  </div>

  <!-- About -->
  <hr>

  <div id="about" style="
    margin-top:40px;
    padding:25px;
    background:white;
    border-radius:10px;
    box-shadow:0 2px 8px rgba(0,0,0,0.05);
  ">

  <div style="display:flex; align-items:center; gap:20px;">
  <img src="/images/author.png" style="
    width:100px;
    height:100px;
    border-radius:50%;
    object-fit:cover;
  ">

  <p style="color:#555; line-height:1.7;">
    Dr. Mini Sherino is a visionary academic and distinguished professional whose path of purpose is marked by excellence, intellectual depth, and refined commitment to Christian morality.
      <br><br>
      The Word of God is a lamp to our feet and a light to our path. It transforms, restores, and guides us toward a life filled with grace and purpose. 
  </p>
</div>
  <!-- Footer -->
  <div style="
    text-align:center;
    margin-top:20px;
    color:#777;
    font-size:14px;
  ">
    © 2026 Dr. Mini Sherino. All rights reserved.
  </div>

</div>
</div>

<!-- Scripts -->
<script>
let visiblePosts = 5;

function loadMore() {
  const posts = document.querySelectorAll(".post-item");

  for (let i = 0; i < visiblePosts; i++) {
    if (posts[i]) posts[i].style.display = "block";
  }

  visiblePosts += 5;
}

function randomPost() {
  const links = document.querySelectorAll("#postList a");
  const random = links[Math.floor(Math.random() * links.length)];
  window.location = random.href;
}

// Initial load
window.onload = loadMore;
</script>

<script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>

<script>
  window.addEventListener("load", function () {
    if (window.netlifyIdentity) {
      window.netlifyIdentity.on("init", user => {

        if (!user && (
          window.location.hash.includes("confirmation_token") ||
          window.location.hash.includes("recovery_token")
        )) {
          window.netlifyIdentity.open();
        }
      });

      window.netlifyIdentity.init();
    }
  });
</script>